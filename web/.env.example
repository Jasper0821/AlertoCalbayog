# Copy this file to .env.local and set the correct backend IP for your machine.
# 
# If you are running the backend yourself:
#   VITE_API_URL=http://localhost:5000
#
# If someone else on your team is hosting the backend (e.g. Jasper's PC on LAN):
#   VITE_API_URL=http://192.168.254.123:5000
#
# To find the host's IP: run  ipconfig  on their PC and look for "IPv4 Address"

VITE_API_URL=http://localhost:5000
